# 只在服务端读取。部署到 Vercel 后，在 Project Settings > Environment Variables 中配置。
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# DeepSeek 辅食小助手（只在服务端读取）
DEEPSEEK_API_KEY=
DEEPSEEK_AGENT_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问视频分析（只在服务端读取）
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.7-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Vercel 生产环境的大文件直传和任务持久化。连接 Vercel Blob 后自动生成。
BLOB_READ_WRITE_TOKEN=

# 可选；默认使用 node_modules/ffmpeg-static/ffmpeg
FFMPEG_PATH=

# 抖音 / TikTok 分享链接解析（只在服务端读取）
TIKHUB_API_KEY=
# Vercel 等海外运行环境使用 .io；中国大陆服务器改为 https://api.tikhub.dev
TIKHUB_BASE_URL=https://api.tikhub.io
