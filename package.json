{
  "name": "baobao-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "assets:ip": "node scripts/build-ip-assets.mjs",
    "assets:profile": "node scripts/build-profile-assets.mjs",
    "assets:home-character": "node scripts/build-home-chick-lottie.mjs",
    "assets:food": "node scripts/build-food-assets.mjs",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run lint && vitest run --config vitest.config.ts && npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@lottiefiles/dotlottie-react": "^0.19.12",
    "@tanstack/react-query": "^5.101.4",
    "@vercel/blob": "^2.6.1",
    "@vercel/functions": "^3.7.5",
    "dexie": "^4.4.4",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "openai": "^6.48.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.82.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
